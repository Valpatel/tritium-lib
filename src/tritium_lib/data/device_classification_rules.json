{
  "_description": "Master device classification ruleset combining all sources. Defines priority order and confidence thresholds for device identification.",
  "_updated": "2026-03-14",
  "classification_priority": [
    {"source": "ble_appearance", "weight": 0.95, "description": "BLE GAP Appearance value — explicitly declared device type"},
    {"source": "apple_continuity_device_type", "weight": 0.95, "description": "Apple Continuity protocol device type byte"},
    {"source": "ble_name_pattern", "weight": 0.90, "description": "BLE advertised name matched against known patterns"},
    {"source": "google_fast_pair_model", "weight": 0.90, "description": "Google Fast Pair model ID → known device"},
    {"source": "apple_proximity_pairing", "weight": 0.90, "description": "Apple proximity pairing model ID"},
    {"source": "ble_service_uuids", "weight": 0.80, "description": "BLE service UUIDs indicate device capabilities"},
    {"source": "ble_company_id", "weight": 0.70, "description": "BLE manufacturer company ID from advertising data"},
    {"source": "oui_lookup", "weight": 0.60, "description": "MAC OUI prefix → manufacturer → likely device types"},
    {"source": "wifi_ssid_pattern", "weight": 0.85, "description": "WiFi SSID matched against known patterns"},
    {"source": "dhcp_vendor_class", "weight": 0.80, "description": "DHCP Option 60 vendor class identifier"},
    {"source": "dhcp_hostname", "weight": 0.75, "description": "DHCP hostname pattern matching"},
    {"source": "mdns_services", "weight": 0.70, "description": "mDNS/Bonjour advertised services"}
  ],
