  "alliance_rules": {
    "_description": "Rules for determining target alliance (friendly/hostile/unknown) based on device characteristics",
    "friendly_indicators": [
      {"condition": "device in known_devices_list", "confidence": 0.95},
      {"condition": "manufacturer in trusted_manufacturers", "confidence": 0.60},
      {"condition": "oui matches fleet device", "confidence": 0.90}
    ],
    "hostile_indicators": [
      {"condition": "device in threat_feed", "confidence": 0.90},
      {"condition": "randomized MAC + no name + strong signal", "confidence": 0.40},
      {"condition": "known attack tool SSID (Pineapple, FlipperZero probe)", "confidence": 0.70}
    ],
    "suspicious_patterns": [
      {"pattern": "MAC address randomization (local bit set, XX:XX:XX where second hex char is 2,6,A,E)", "confidence": 0.30},
      {"pattern": "Rapid MAC rotation (same device class, different MACs)", "confidence": 0.50},
      {"pattern": "Probe request for known evil twin SSIDs", "confidence": 0.60},
      {"pattern": "Deauth flood source", "confidence": 0.90},
      {"pattern": "Hidden SSID broadcast with no matching probe response", "confidence": 0.40}
    ]
  },
  "mac_randomization_detection": {
    "_description": "How to detect randomized MAC addresses (common in modern phones/tablets)",
    "local_bit_check": "If bit 1 of the first octet is set (second hex char is 2,3,6,7,A,B,E,F), the MAC is locally administered (likely randomized)",
    "common_random_oui_ranges": [
      {"prefix": "02:", "description": "Generic locally administered"},
      {"prefix": "06:", "description": "Generic locally administered"},
      {"prefix": "0A:", "description": "Generic locally administered"},
      {"prefix": "0E:", "description": "Generic locally administered"},
      {"prefix": "12:", "description": "Generic locally administered"},
      {"prefix": "16:", "description": "Generic locally administered"},
      {"prefix": "1A:", "description": "Generic locally administered"},
      {"prefix": "1E:", "description": "Generic locally administered"}
    ],
    "implication": "Randomized MACs mean OUI lookup is unreliable. Use BLE advertising data (name, appearance, services, manufacturer data) for classification instead."
  },
  "beacon_formats": {
    "iBeacon": {
      "company_id": "0x004C",
      "adv_indicator": "0x0215",
      "fields": ["uuid (16 bytes)", "major (2 bytes)", "minor (2 bytes)", "tx_power (1 byte)"],
      "device_type": "beacon"
    },
    "Eddystone": {
      "service_uuid": "0xFEAA",
      "frame_types": {
        "0x00": "Eddystone-UID",
        "0x10": "Eddystone-URL",
        "0x20": "Eddystone-TLM",
        "0x30": "Eddystone-EID"
      },
      "device_type": "beacon"
    },
    "AltBeacon": {
      "manufacturer_id": "0xBEAC",
      "fields": ["beacon_id (20 bytes)", "reference_rssi (1 byte)", "mfg_reserved (1 byte)"],
      "device_type": "beacon"
    },
    "Microsoft_Swift_Pair": {
      "company_id": "0x0006",
      "scenario_type": "0x01",
      "fields": ["scenario_type (1 byte)", "rssi_threshold (1 byte)", "device_info (variable)"],
      "device_type": null
    }
  }
